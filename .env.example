# --- Profile ---
SPRING_PROFILES_ACTIVE=dev

# --- Database (Neon / Postgres) ---
# IMPORTANT: rotate any credentials that have been shared in plaintext.
DATABASE_URL=jdbc:postgresql://HOST:5432/DBNAME?sslmode=require
DATABASE_USERNAME=
DATABASE_PASSWORD=
DB_POOL_MAX=20
DB_POOL_MIN=5

# --- Server ---
SERVER_PORT=8080
APP_BASE_URL=http://localhost:8080

# --- Frontends / CORS ---
FRONTEND_PUBLIC_URL=http://localhost:3000
FRONTEND_PORTAL_URL=http://localhost:3001
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173,http://localhost:5174

# --- JWT ---
JWT_ISSUER=eduplatform
# Must be >= 32 bytes for HS256 (base64-encoded recommended)
JWT_ACCESS_SECRET=change-me-to-a-long-random-base64-secret
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=30

# --- Mail ---
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# --- OAuth: Google ---
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=

# --- OAuth: Facebook ---
OAUTH_FACEBOOK_APP_ID=
OAUTH_FACEBOOK_APP_SECRET=

# --- OAuth: Apple (Sign in with Apple) ---
APPLE_TEAM_ID=
APPLE_SERVICES_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_PEM=

# --- Storage ---
STORAGE_PROVIDER=LOCAL
STORAGE_LOCAL_DIR=./var/uploads
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# --- Logging ---
LOG_LEVEL_APP=DEBUG
LOG_LEVEL_SQL=WARN
